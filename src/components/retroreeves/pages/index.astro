</main>

<script>
  // ── CARRUSEL ──────────────────────────────────────────
  const slides   = document.querySelectorAll<HTMLElement>('.rr-hero__slide');
  const dots     = document.querySelectorAll<HTMLElement>('.rr-hero__dot');
  const progress = document.getElementById('hero-progress') as HTMLElement;
  const INTERVAL = 5000;
  let current = 0;
  let timer: ReturnType<typeof setTimeout>;
  let progTimer: ReturnType<typeof setTimeout>;

  function goTo(idx: number) {
    slides[current]?.classList.remove('active');
    dots[current]?.classList.remove('active');
    current = (idx + slides.length) % slides.length;
    slides[current]?.classList.add('active');
    dots[current]?.classList.add('active');
    startProgress();
  }

  function startProgress() {
    clearTimeout(progTimer);
    if (!progress) return;
    progress.style.transition = 'none';
    progress.style.width = '0%';
    // Force reflow
    progress.offsetWidth;
    progress.style.transition = `width ${INTERVAL}ms linear`;
    progress.style.width = '100%';
  }

  function autoPlay() {
    clearTimeout(timer);
    timer = setTimeout(() => { goTo(current + 1); autoPlay(); }, INTERVAL);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.slide ?? '0');
      goTo(idx);
      clearTimeout(timer);
      autoPlay();
    });
  });

  if (slides.length > 1) { startProgress(); autoPlay(); }

  // ── COUNTDOWN ─────────────────────────────────────────
  const cdEl = document.getElementById('hero-countdown');
  if (cdEl?.dataset.end) {
    const end = new Date(cdEl.dataset.end).getTime();
    function pad(n: number) { return String(n).padStart(2, '0'); }
    function tickCD() {
      const diff = end - Date.now();
      if (diff <= 0) { cdEl.innerHTML = '<span style="font-family:monospace;font-size:.7rem;color:rgba(255,255,255,.4);letter-spacing:.15em">AGOTADO</span>'; return; }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      const set = (id: string, val: string) => {
        const el = document.getElementById(id);
        if (!el) return;
        if (el.textContent !== val) {
          el.textContent = val;
          el.classList.add('tick');
          setTimeout(() => el.classList.remove('tick'), 300);
        }
      };
      set('cd-days',  pad(d));
      set('cd-hours', pad(h));
      set('cd-mins',  pad(m));
      set('cd-secs',  pad(s));
    }
    tickCD();
    setInterval(tickCD, 1000);
  }

  // ── PARALLAX ──────────────────────────────────────────
  const hero = document.getElementById('rr-hero');
  function onScroll() {
    if (!hero) return;
    const scrollY = window.scrollY;
    const heroH   = hero.offsetHeight;
    if (scrollY > heroH) return;
    const pct = scrollY / heroH;
    // Mueve los slides hacia arriba ligeramente al hacer scroll
    document.querySelectorAll<HTMLElement>('.rr-hero__slide').forEach(s => {
      s.style.transform = s.classList.contains('active')
        ? `scale(1) translateY(${pct * 12}%)`
        : `scale(1.06) translateY(${pct * 12}%)`;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  // ── SCROLL REVEAL ──────────────────────────────────────
  const revealEls = document.querySelectorAll('.rr-reveal');
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  revealEls.forEach(el => io.observe(el));
</script>

<script define:vars={{ products, base }} is:inline>
  window.__RR_PRODUCTS__ = products;
</script>
