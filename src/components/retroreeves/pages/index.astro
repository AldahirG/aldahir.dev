---
import Layout from '../layouts/Layout.astro';
import '../../assets/scss/astro-ecommerce.scss';
import Navbar from '../components/navbar';
import Footer from '../components/footer';
import QuickviewModal from '../components/products/QuickviewModal.astro';
import { getProducts } from '../lib/products';
import { getDrops } from '../lib/drops';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const products    = await getProducts();
const drops       = await getDrops();
const heroDrop    = drops[0];

// No prefijar URLs absolutas (Sanity CDN) con base
const url = (src: string) => src?.startsWith('http') ? src : `${base}/${src}`;

// Hero slides: heroImage del drop activo + imágenes del primer producto del drop
const heroProducts = products.filter(p => (p as any).dropSlug === heroDrop?.slug);
const heroSlides = [
  heroDrop?.heroImage,
  ...heroProducts.flatMap(p => p.images).slice(0, 3),
].filter(Boolean).map(src => url(src));

const hiddenCategories = ['gorras', 'zapatos'];
const visibleProducts = products.filter(p => !hiddenCategories.includes(p.category));
const bestsellers = visibleProducts.filter(p => (p as any).bestseller).slice(0, 4).length
  ? visibleProducts.filter(p => (p as any).bestseller).slice(0, 4)
  : visibleProducts.slice(0, 4);

// Lookbook: primeras 5 imágenes de productos visibles
const lookbookImgs = visibleProducts
  .flatMap(p => p.images.map(img => ({ img: url(img), name: p.name, price: p.price, slug: p.slug })))
  .slice(0, 5);

const categories = [
  { label: 'Hoodies',     slug: 'hoodies',    icon: 'bi-box-seam'      },
  { label: 'Gym',         slug: 'gym',         icon: 'bi-lightning-fill'},
  { label: 'Manga Corta', slug: 'manga-corta', icon: 'bi-person'        },
  { label: 'Anime',       slug: 'anime',       icon: 'bi-stars'         },
];
---

<Layout title="Retro Reeves — Streetwear · Anime · Gym">
<style>
  :root {
    --rr-ink:    #0d0d0d;
    --rr-paper:  #ffffff;
    --rr-muted:  #f5f5f3;
    --rr-border: rgba(0,0,0,0.10);
    --rr-mono:   "PT Mono", monospace;
    --rr-sans:   "Noto Sans", sans-serif;
  }
 * { box-sizing: border-box; }
  html, body { overflow-x: hidden; max-width: 100%; }
  .container { overflow-x: hidden; }

  /* ── HERO CARRUSEL ─────────────────────────────────── */
  .rr-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    margin-top: -64px;
    overflow: hidden;
    background: var(--rr-ink);
  }

  .rr-hero__slides {
    position: absolute;
    inset: 0;
  }
  .rr-hero__slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transform: scale(1.06);
    transition: opacity 1s ease, transform 7s ease;
    will-change: opacity, transform;
    filter: brightness(0.48);
  }
  .rr-hero__slide.active {
    opacity: 1;
    transform: scale(1);
  }

  /* Parallax layer — se mueve con scroll vía JS */
  .rr-hero__parallax {
    position: absolute;
    inset: -15%;
    pointer-events: none;
  }

  .rr-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.85) 0%,
      rgba(0,0,0,0.2)  55%,
      transparent       100%
    );
    pointer-events: none;
  }

  /* Contenido del hero */
  .rr-hero__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 2rem 3.5rem;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-end;
    gap: 2rem;
  }
  .rr-hero__left { max-width: 640px; }

  .rr-hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--rr-mono);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.35);
    padding: 0.3rem 0.8rem;
    margin-bottom: 1rem;
  }
  .rr-hero__tag-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.4); }
  }

  .rr-hero__title {
    font-family: var(--rr-sans);
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: #fff;
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .rr-hero__title-inner {
    display: block;
    transform: translateY(100%);
    animation: slideUp 0.8s 0.2s cubic-bezier(.16,1,.3,1) forwards;
  }
  @keyframes slideUp {
    to { transform: translateY(0); }
  }

  .rr-hero__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeIn 0.6s 0.6s ease forwards;
  }
  @keyframes fadeIn { to { opacity: 1; } }

  .rr-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--rr-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: #fff;
    color: var(--rr-ink);
    padding: 0.9rem 2rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    opacity: 0;
    animation: fadeIn 0.6s 0.8s ease forwards;
  }
  .rr-hero__cta:hover { background: transparent; color: #fff; border-color: #fff; }

  /* Countdown — lado derecho del hero */
  .rr-hero__countdown {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeIn 0.6s 1s ease forwards;
  }
  .rr-countdown__label {
    font-family: var(--rr-mono);
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }
  .rr-countdown__units {
    display: flex;
    gap: 0.35rem;
    align-items: flex-end;
  }
  .rr-countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 56px;
  }
  .rr-countdown__num {
    font-family: var(--rr-mono);
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    transition: color 0.3s;
  }
  .rr-countdown__num.tick { color: #4ade80; }
  .rr-countdown__unit-label {
    font-family: var(--rr-mono);
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-top: 0.2rem;
  }
  .rr-countdown__sep {
    font-family: var(--rr-mono);
    font-size: 1.8rem;
    color: rgba(255,255,255,0.2);
    padding-bottom: 0.3rem;
    line-height: 1;
  }

  /* Dots del carrusel */
  .rr-hero__dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 3;
  }
  .rr-hero__dot {
    width: 24px;
    height: 2px;
    background: rgba(255,255,255,0.3);
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
    border: none;
    padding: 0;
  }
  .rr-hero__dot.active {
    background: #fff;
    width: 48px;
  }

  /* Progress bar */
  .rr-hero__progress {
    position: absolute;
    top: 64px;
    left: 0;
    height: 2px;
    background: rgba(255,255,255,0.7);
    width: 0%;
    z-index: 3;
    transition: width linear;
  }

  @media (max-width: 640px) {
.rr-hero__content { grid-template-columns: 1fr; padding: 0 1.25rem 3rem; }
    .rr-hero__countdown { display: none; }
  }

  /* ── TICKER ─────────────────────────────────────────── */
  .rr-ticker {
    overflow-x: hidden;
    background: var(--rr-ink);
    color: #fff;
    padding: 0.6rem 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .rr-ticker__inner {
    display: inline-flex;
    gap: 2.5rem;
    animation: ticker 30s linear infinite;
  }
  .rr-ticker__inner:hover { animation-play-state: paused; }
  .rr-ticker span {
    font-family: var(--rr-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .rr-ticker .sep { color: rgba(255,255,255,0.25); }
  .rr-ticker .hl  { color: #4ade80; }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ── SECTION ────────────────────────────────────────── */
  .rr-section { padding: 4.5rem 0; }
  .rr-section__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--rr-border);
    padding-bottom: 0.75rem;
    margin-bottom: 2rem;
  }
  .rr-section__title {
    font-family: var(--rr-sans);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.03em;
  }
  .rr-section__link {
    font-family: var(--rr-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rr-ink);
    text-decoration: none;
    opacity: 0.4;
    transition: opacity 0.2s;
  }
  .rr-section__link:hover { opacity: 1; }

  /* ── DROPS GRID ─────────────────────────────────────── */
  .rr-drops-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 768px) {
    .rr-drops-grid { grid-template-columns: 1fr 1fr; }
    .rr-drop-card:first-child { grid-column: span 2; }
  }
  .rr-drop-card {
    position: relative;
    overflow: hidden;
    background: var(--rr-muted);
    text-decoration: none;
    color: var(--rr-ink);
    display: block;
    transition: transform 0.3s cubic-bezier(.22,.68,0,1.2);
  }
  .rr-drop-card:hover { transform: translateY(-4px); }
  .rr-drop-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .rr-drop-card:hover .rr-drop-card__img { transform: scale(1.04); }
  .rr-drop-card__badge {
    position: absolute;
    top: 0.85rem; left: 0.85rem;
    font-family: var(--rr-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--rr-ink);
    color: #fff;
    padding: 0.25rem 0.65rem;
  }
  .rr-drop-card__info {
    padding: 1rem;
    border-top: 1px solid var(--rr-border);
  }
  .rr-drop-card__name {
    font-family: var(--rr-sans);
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
  }
  .rr-drop-card__meta {
    font-family: var(--rr-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: rgba(0,0,0,0.4);
  }

  /* ── CATEGORIES ─────────────────────────────────────── */
  .rr-categories {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }
  @media (max-width: 600px) { .rr-categories { grid-template-columns: repeat(2,1fr); } }
  .rr-cat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--rr-ink);
    padding: 1.25rem 0.5rem;
    border: 1px solid var(--rr-border);
    transition: border-color 0.2s, background 0.2s;
  }
  .rr-cat:hover { border-color: var(--rr-ink); background: var(--rr-muted); }
  .rr-cat i { font-size: 1.4rem; }
  .rr-cat__label {
    font-family: var(--rr-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* ── LOOKBOOK ───────────────────────────────────────── */
  .rr-lookbook { background: var(--rr-ink); padding: 4.5rem 0; }
  .rr-lookbook__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.75rem;
    margin-bottom: 2rem;
  }
  .rr-lookbook__title {
    font-family: var(--rr-sans);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.03em;
    color: #fff;
  }
  .rr-lookbook__link {
    font-family: var(--rr-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.2s;
  }
  .rr-lookbook__link:hover { color: #fff; }

  .rr-lookbook__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 0.5rem;
  }
  @media (max-width: 640px) { .rr-lookbook__grid { grid-template-columns: 1fr 1fr; } }

  .rr-lookbook__item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .rr-lookbook__item:first-child {
    grid-row: span 2;
  }
  .rr-lookbook__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
    min-height: 200px;
  }
  .rr-lookbook__item:hover img { transform: scale(1.05); }

  .rr-lookbook__item-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }
  .rr-lookbook__item:hover .rr-lookbook__item-info { transform: translateY(0); }

  .rr-lookbook__item-name {
    font-family: var(--rr-sans);
    font-weight: 700;
    font-size: 0.85rem;
    color: #fff;
    margin-bottom: 0.2rem;
  }
  .rr-lookbook__item-price {
    font-family: var(--rr-mono);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.7);
  }

  /* ── PRODUCTS GRID ──────────────────────────────────── */
  .rr-products-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) { .rr-products-grid { grid-template-columns: repeat(2,1fr); } }

  .rr-product-card {
    border: 1px solid var(--rr-border);
    text-decoration: none;
    color: var(--rr-ink);
    display: block;
    transition: transform 0.3s cubic-bezier(.22,.68,0,1.2), border-color 0.2s;
    position: relative;
    overflow: hidden;
  }
  .rr-product-card:hover { transform: translateY(-5px); border-color: var(--rr-ink); }

  .rr-product-card__img-wrap {
    overflow: hidden;
    background: var(--rr-muted);
    aspect-ratio: 3/4;
    position: relative;
  }
  /* Hover: muestra segunda imagen */
  .rr-product-card__img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
    transition: opacity 0.4s ease, transform 0.5s ease;
  }
  .rr-product-card__img--primary  { opacity: 1; transform: scale(1); }
  .rr-product-card__img--secondary { opacity: 0; transform: scale(1.04); }
  .rr-product-card:hover .rr-product-card__img--primary  { opacity: 0; }
  .rr-product-card:hover .rr-product-card__img--secondary { opacity: 1; transform: scale(1); }

  .rr-product-card__info {
    padding: 0.85rem;
    border-top: 1px solid var(--rr-border);
  }
  .rr-product-card__name {
    font-family: var(--rr-sans);
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 0.2rem;
  }
  .rr-product-card__sizes {
    font-family: var(--rr-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    color: rgba(0,0,0,0.4);
    margin-bottom: 0.5rem;
  }
  .rr-product-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .rr-product-card__price {
    font-family: var(--rr-mono);
    font-weight: 700;
    font-size: 0.88rem;
  }
  .rr-product-card__tag {
    font-family: var(--rr-mono);
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--rr-ink);
    color: #fff;
    padding: 0.2rem 0.55rem;
  }

  /* ── QUICK VIEW BTN ────────────────────────────────────── */
  .rr-qv-trigger {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    opacity: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--rr-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(255,255,255,0.92);
    color: var(--rr-ink);
    border: none;
    padding: 0.55rem 1.1rem;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.25s ease, transform 0.25s ease;
    backdrop-filter: blur(4px);
  }
  .rr-product-card:hover .rr-qv-trigger {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .rr-qv-trigger:hover { background: #fff; }

  /* ── WA BANNER ──────────────────────────────────────── */
  .rr-wa-banner {
    background: var(--rr-ink);
    color: #fff;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }
  .rr-wa-banner__eyebrow {
    font-family: var(--rr-mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }
  .rr-wa-banner__title {
    font-family: var(--rr-sans);
    font-weight: 800;
    font-size: clamp(1.8rem, 5vw, 3rem);
    letter-spacing: -0.03em;
    line-height: 1;
    max-width: 560px;
  }
  .rr-wa-banner__sub {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.5);
    max-width: 400px;
  }
  .rr-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--rr-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: #fff;
    color: var(--rr-ink);
    padding: 1rem 2.25rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .rr-wa-btn:hover { opacity: 0.85; }

  /* ── SCROLL REVEAL ──────────────────────────────────── */
  .rr-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .rr-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .rr-reveal-delay-1 { transition-delay: 0.1s; }
  .rr-reveal-delay-2 { transition-delay: 0.2s; }
  .rr-reveal-delay-3 { transition-delay: 0.3s; }
</style>

<main>
  <Navbar client:load />

  <!-- ══ HERO CARRUSEL ══ -->
  <section class="rr-hero" id="rr-hero">
    <!-- Slides -->
    <div class="rr-hero__slides" id="hero-slides">
      {heroSlides.map((src, i) => (
        <div
          class={`rr-hero__slide${i === 0 ? ' active' : ''}`}
          style={`background-image: url('${src}')`}
          data-index={i}
        />
      ))}
    </div>

    <!-- Parallax wrapper -->
    <div class="rr-hero__parallax" id="hero-parallax" />

    <!-- Overlay gradiente -->
    <div class="rr-hero__overlay" />

    <!-- Progress bar -->
    <div class="rr-hero__progress" id="hero-progress" />

    <!-- Contenido -->
    <div class="rr-hero__content container">
      <div class="rr-hero__left">
        <div class="rr-hero__tag">
          <span class="rr-hero__tag-dot" />
          Drop activo
        </div>
        <h1 class="rr-hero__title">
          <span class="rr-hero__title-inner">{heroDrop?.name ?? 'Retro Reeves'}</span>
        </h1>
        <p class="rr-hero__sub">{heroDrop?.subtitle ?? 'Streetwear · Anime · Gym · Cultura'}</p>
        <a href={`${base}/coleccion/${heroDrop?.slug ?? ''}`} class="rr-hero__cta">
          Ver colección →
        </a>
      </div>

      <!-- Countdown -->
      <div class="rr-hero__countdown" id="hero-countdown" data-end={heroDrop?.endDate}>
        <span class="rr-countdown__label">Disponible hasta</span>
        <div class="rr-countdown__units">
          <div class="rr-countdown__unit">
            <span class="rr-countdown__num" id="cd-days">--</span>
            <span class="rr-countdown__unit-label">días</span>
          </div>
          <span class="rr-countdown__sep">:</span>
          <div class="rr-countdown__unit">
            <span class="rr-countdown__num" id="cd-hours">--</span>
            <span class="rr-countdown__unit-label">hrs</span>
          </div>
          <span class="rr-countdown__sep">:</span>
          <div class="rr-countdown__unit">
            <span class="rr-countdown__num" id="cd-mins">--</span>
            <span class="rr-countdown__unit-label">min</span>
          </div>
          <span class="rr-countdown__sep">:</span>
          <div class="rr-countdown__unit">
            <span class="rr-countdown__num" id="cd-secs">--</span>
            <span class="rr-countdown__unit-label">seg</span>
