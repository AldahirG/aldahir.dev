---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar';
import Footer from '../components/footer';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Carrito — Retro Reeves">
<style is:global>
/* ═══════════════════════════════════════════════════════
   RESET COMPLETO — neutralizar Bootstrap en toda la página
   is:global requerido: los tickets y controles son generados
   por JS (innerHTML) y Astro no puede scopearlos.
   ══════════════════════════════════════════════════════ */
.rr-cart,
.rr-cart *,
.rr-cart *::before,
.rr-cart *::after {
  box-sizing: border-box !important;
}
.rr-cart img { max-width: none !important; }
.rr-cart a   { text-decoration: none !important; }

/* Bootstrap resetea display en botones; lo forzamos aquí */
.rr-cart button,
.rr-cart .rr-qty__btn,
.rr-cart .rr-ticket__remove,
.rr-cart .rr-btn,
.rr-cart .rr-back {
  border-radius: 0 !important;
  box-shadow: none !important;
  outline: none !important;
  -webkit-appearance: none !important;
}

/* Navbar oscura */
.rr-cart nav[role="navigation"] {
  background: #0d0d0d !important;
  backdrop-filter: none !important;
  border-bottom: none !important;
}
.rr-cart nav[role="navigation"] a,
.rr-cart nav[role="navigation"] span { color: #fff !important; }
.rr-cart nav[role="navigation"] svg  { stroke: #fff; color: #fff; }

/* ═══════════════════════════════════════════════════════
   HERO
   ══════════════════════════════════════════════════════ */
.rr-hero {
  background: #0d0d0d;
  padding: 5.5rem 0 2.5rem;
}
.rr-hero__title {
  font-family: 'Noto Sans', sans-serif !important;
  font-weight: 800 !important;
  font-size: clamp(2.2rem, 5vw, 3.6rem) !important;
  letter-spacing: -0.04em !important;
  color: #fff !important;
  margin: 0 0 0.3rem !important;
  line-height: 1 !important;
}
.rr-hero__sub {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.6rem !important;
  letter-spacing: 0.15em !important;
  text-transform: uppercase !important;
  color: rgba(255,255,255,0.38) !important;
  margin: 0 !important;
}

/* ═══════════════════════════════════════════════════════
   BARRA ENVÍO GRATIS
   ══════════════════════════════════════════════════════ */
.rr-sb-wrap {
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,0.10);
  padding: 0.8rem 0;
}
.rr-sb-row {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  margin-bottom: 0.4rem !important;
  gap: 0.5rem !important;
}
.rr-sb-lbl {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.58rem !important;
  letter-spacing: 0.1em !important;
  text-transform: uppercase !important;
  color: rgba(0,0,0,0.45) !important;
  margin: 0 !important;
  line-height: 1.4 !important;
}
.rr-sb-lbl strong { color: #0d0d0d !important; font-weight: 700 !important; }
.rr-sb-lbl.free strong { color: #16a34a !important; }
.rr-sb-pct {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.55rem !important;
  color: rgba(0,0,0,0.3) !important;
  white-space: nowrap !important;
  flex-shrink: 0 !important;
}
.rr-sb-track {
  height: 7px !important;
  background: rgba(0,0,0,0.12) !important;
  border-radius: 4px !important;
  overflow: hidden !important;
}
.rr-sb-bar {
  height: 7px !important;
  background: #16a34a !important;
  border-radius: 4px !important;
  width: 0% !important;
  transition: width 0.7s cubic-bezier(0.22,0.61,0.36,1) !important;
}
.rr-sb-bar.free { background: #16a34a !important; }

/* ═══════════════════════════════════════════════════════
   STEPS
   ══════════════════════════════════════════════════════ */
.rr-steps-wrap {
  background: #f5f4ef;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}
.rr-steps {
  display: flex !important;
  align-items: center !important;
  padding: 0.85rem 0 !important;
  gap: 0 !important;
  overflow-x: auto !important;
  -webkit-overflow-scrolling: touch;
}
.rr-step {
  display: flex !important;
  align-items: center !important;
  gap: 0.38rem !important;
  font-family: 'PT Mono', monospace !important;
  font-size: 0.55rem !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  color: rgba(0,0,0,0.28) !important;
  white-space: nowrap !important;
  flex-shrink: 0 !important;
  transition: color 0.3s !important;
}
.rr-step.active { color: #0d0d0d !important; }
.rr-step.done   { color: #16a34a !important; }
.rr-step__num {
  width: 20px !important;
  height: 20px !important;
  border-radius: 50% !important;
  border: 1.5px solid currentColor !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 0.55rem !important;
  font-weight: 700 !important;
  flex-shrink: 0 !important;
  transition: all 0.3s !important;
  line-height: 1 !important;
}
.rr-step.active .rr-step__num { background: #0d0d0d !important; color: #fff !important; border-color: #0d0d0d !important; }
.rr-step.done   .rr-step__num { background: #16a34a !important; color: #fff !important; border-color: #16a34a !important; }
.rr-step__sep {
  width: 24px !important;
  height: 1px !important;
  background: rgba(0,0,0,0.12) !important;
  margin: 0 0.35rem !important;
  flex-shrink: 0 !important;
}

/* ═══════════════════════════════════════════════════════
   LAYOUT PRINCIPAL
   ══════════════════════════════════════════════════════ */
.rr-main {
  background: #f5f4ef;
  padding: 1.5rem 0 5rem;
  min-height: 55vh;
}
.rr-layout {
  display: grid !important;
  grid-template-columns: 1fr 320px !important;
  gap: 1.25rem !important;
  align-items: start !important;
}
/* Móvil: sidebar ABAJO del contenido de items */
@media (max-width: 860px) {
  .rr-layout {
    grid-template-columns: 1fr !important;
  }
  .rr-col-left {
    order: 1 !important;
  }
  .rr-sidebar {
    order: 2 !important;
    position: static !important;
    top: auto !important;
  }
}

/* ═══════════════════════════════════════════════════════
   PANEL
   ══════════════════════════════════════════════════════ */
.rr-panel {
  background: #fff !important;
  padding: 1.35rem !important;
  margin-bottom: 1rem !important;
}
.rr-panel__title {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.52rem !important;
  letter-spacing: 0.18em !important;
  text-transform: uppercase !important;
  color: rgba(0,0,0,0.3) !important;
  margin: 0 0 1.2rem !important;
  padding-bottom: 0.65rem !important;
  border-bottom: 1px solid rgba(0,0,0,0.08) !important;
  display: block !important;
}

/* ═══════════════════════════════════════════════════════
   TICKET — item del carrito
   ══════════════════════════════════════════════════════ */
.rr-ticket {
  position: relative !important;
  border: 1px solid rgba(0,0,0,0.10) !important;
  background: #fff !important;
  margin-bottom: 0.75rem !important;
  overflow: hidden !important;
  border-radius: 0 !important;
  transition: transform 0.2s ease, opacity 0.28s ease !important;
}
.rr-ticket:last-child { margin-bottom: 0 !important; }
.rr-ticket::before {
  content: '' !important;
  position: absolute !important;
  top: 0 !important; left: 0 !important;
  width: 0 !important; height: 100% !important;
  background: transparent !important;
}
.rr-ticket.drop::before { background: #c8382a !important; }
.rr-ticket.removing {
  transform: translateX(28px) !important;
  opacity: 0 !important;
  pointer-events: none !important;
}

.rr-ticket__body {
  display: grid !important;
  grid-template-columns: 70px 1fr !important;
  gap: 0 !important;
}
@media (max-width: 400px) {
  .rr-ticket__body { grid-template-columns: 56px 1fr !important; }
}

.rr-ticket__img {
  width: 70px !important;
  height: 90px !important;
  overflow: hidden !important;
  background: #f5f4ef !important;
  flex-shrink: 0 !important;
  display: block !important;
}
.rr-ticket__img img {
  width: 70px !important;
  height: 90px !important;
  max-width: 70px !important;
  object-fit: cover !important;
  display: block !important;
}
@media (max-width: 400px) {
  .rr-ticket__img       { width: 56px !important; height: 72px !important; }
  .rr-ticket__img img   { width: 56px !important; height: 72px !important; max-width: 56px !important; }
}

.rr-ticket__info {
  padding: 0.7rem 2.2rem 0 0.85rem !important;
}
.rr-ticket__name {
  font-family: 'Noto Sans', sans-serif !important;
  font-weight: 700 !important;
  font-size: 0.88rem !important;
  color: #0d0d0d !important;
  margin: 0 0 0.18rem !important;
  line-height: 1.25 !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  display: block !important;
}
.rr-ticket__meta {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.54rem !important;
  letter-spacing: 0.09em !important;
  text-transform: uppercase !important;
  color: rgba(0,0,0,0.38) !important;
  display: block !important;
  line-height: 1.5 !important;
  margin: 0 !important;
}
.rr-ticket__badge {
  display: inline-block !important;
  background: #c8382a !important;
  color: #fff !important;
  font-family: 'PT Mono', monospace !important;
  font-size: 0.42rem !important;
  letter-spacing: 0.1em !important;
  text-transform: uppercase !important;
  padding: 1px 5px !important;
  margin-left: 0.3rem !important;
  vertical-align: middle !important;
  line-height: 1.6 !important;
  border-radius: 0 !important;
}
.rr-ticket__sep {
  border: none !important;
  border-top: 1.5px dashed rgba(0,0,0,0.10) !important;
  margin: 0 0.85rem !important;
  display: block !important;
}
.rr-ticket__foot {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  padding: 0.5rem 0.85rem 0.65rem !important;
  gap: 0.5rem !important;
}
.rr-ticket__price {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.9rem !important;
  font-weight: 700 !important;
  color: #0d0d0d !important;
  letter-spacing: 0.02em !important;
  line-height: 1 !important;
}
.rr-ticket__price-unit {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.5rem !important;
  color: rgba(0,0,0,0.3) !important;
  font-weight: 400 !important;
  margin-left: 0.18rem !important;
  display: inline !important;
}
.rr-ticket__remove {
  position: absolute !important;
  top: 0.4rem !important;
  right: 0.45rem !important;
  background: none !important;
  border: none !important;
  cursor: pointer !important;
  padding: 2px 4px !important;
  font-family: 'PT Mono', monospace !important;
  font-size: 0.46rem !important;
  letter-spacing: 0.08em !important;
  text-transform: uppercase !important;
  color: rgba(0,0,0,0.22) !important;
  line-height: 1 !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  transition: color 0.18s !important;
  display: inline-block !important;
}
.rr-ticket__remove:hover { color: #c8382a !important; }

/* ═══════════════════════════════════════════════════════
   CONTROLES CANTIDAD
   — Todo con !important para vencer Bootstrap
   ══════════════════════════════════════════════════════ */
.rr-qty {
  display: inline-flex !important;
  align-items: stretch !important;
  border: 1px solid rgba(0,0,0,0.16) !important;
  height: 30px !important;
  overflow: hidden !important;
  border-radius: 0 !important;
  flex-shrink: 0 !important;
}
.rr-qty .rr-qty__btn {
  width: 28px !important;
  height: 30px !important;
  min-width: 28px !important;
  max-width: 28px !important;
  flex: 0 0 28px !important;
  background: #f5f4ef !important;
  border: none !important;
  border-radius: 0 !important;
  cursor: pointer !important;
  font-family: 'PT Mono', monospace !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  color: #0d0d0d !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
  line-height: 1 !important;
  box-shadow: none !important;
  outline: none !important;
  transition: background 0.14s, color 0.14s !important;
  -webkit-appearance: none !important;
}
.rr-qty .rr-qty__btn:hover {
  background: #0d0d0d !important;
  color: #fff !important;
}
.rr-qty .rr-qty__btn:active {
  transform: scale(0.9) !important;
}
.rr-qty__num {
  width: 32px !important;
  min-width: 32px !important;
  height: 30px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-family: 'PT Mono', monospace !important;
  font-size: 0.78rem !important;
  font-weight: 700 !important;
  color: #0d0d0d !important;
  border-left: 1px solid rgba(0,0,0,0.10) !important;
  border-right: 1px solid rgba(0,0,0,0.10) !important;
  background: #fff !important;
  padding: 0 !important;
  line-height: 1 !important;
  transition: transform 0.14s !important;
  user-select: none !important;
}
.rr-qty__num.bump { transform: scale(1.3) !important; }

/* ═══════════════════════════════════════════════════════
   ESTADO VACÍO
   ══════════════════════════════════════════════════════ */
.rr-empty {
  text-align: center !important;
  padding: 3.5rem 1rem !important;
}
.rr-empty__icon  { font-size: 2rem !important; opacity: 0.08 !important; margin-bottom: 0.8rem !important; display: block !important; }
.rr-empty__title { font-family: 'Noto Sans', sans-serif !important; font-weight: 800 !important; font-size: 1rem !important; letter-spacing: -0.02em !important; margin: 0 0 0.3rem !important; color: #0d0d0d !important; }
.rr-empty__sub   { font-family: 'PT Mono', monospace !important; font-size: 0.56rem !important; letter-spacing: 0.1em !important; text-transform: uppercase !important; color: rgba(0,0,0,0.28) !important; margin-bottom: 1.2rem !important; display: block !important; }

/* ═══════════════════════════════════════════════════════
   SUGERIDOS
   ══════════════════════════════════════════════════════ */
.rr-sug-head {
  display: flex !important;
  align-items: center !important;
  gap: 0.65rem !important;
  margin-bottom: 0.85rem !important;
}
.rr-sug-title {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.52rem !important;
  letter-spacing: 0.16em !important;
  text-transform: uppercase !important;
  color: rgba(0,0,0,0.3) !important;
  white-space: nowrap !important;
  margin: 0 !important;
}
.rr-sug-line { flex: 1 !important; height: 1px !important; background: rgba(0,0,0,0.08) !important; }
.rr-sug-grid {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr) !important;
  gap: 0.65rem !important;
}
@media (max-width: 420px) {
  .rr-sug-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
.rr-sug-card {
  background: #fff !important;
  border: 1px solid rgba(0,0,0,0.09) !important;
  overflow: hidden !important;
  display: block !important;
  transition: border-color 0.2s, transform 0.2s !important;
  border-radius: 0 !important;
}
.rr-sug-card:hover { border-color: #0d0d0d !important; transform: translateY(-2px) !important; }
.rr-sug-card__img {
  width: 100% !important;
  aspect-ratio: 3/4 !important;
  background: #f5f4ef !important;
  overflow: hidden !important;
  display: block !important;
}
.rr-sug-card__img img {
  width: 100% !important;
  height: 100% !important;
  max-width: 100% !important;
  object-fit: cover !important;
  display: block !important;
  transition: transform 0.4s !important;
}
.rr-sug-card:hover .rr-sug-card__img img { transform: scale(1.04) !important; }
.rr-sug-card__info { padding: 0.45rem 0.55rem 0.55rem !important; }
.rr-sug-card__name {
  font-family: 'Noto Sans', sans-serif !important;
  font-weight: 700 !important;
  font-size: 0.7rem !important;
  color: #0d0d0d !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  margin: 0 0 0.08rem !important;
  display: block !important;
}
.rr-sug-card__price {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.68rem !important;
  font-weight: 700 !important;
  color: #0d0d0d !important;
  display: block !important;
  margin: 0 !important;
}

/* ═══════════════════════════════════════════════════════
   SIDEBAR
   ══════════════════════════════════════════════════════ */
.rr-sidebar { position: sticky !important; top: 76px !important; }
@media (max-width: 860px) { .rr-sidebar { position: static !important; top: auto !important; } }

.rr-summary {
  background: #0d0d0d !important;
  padding: 1.3rem !important;
  color: #fff !important;
}
.rr-summary__title {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.5rem !important;
  letter-spacing: 0.18em !important;
  text-transform: uppercase !important;
  color: rgba(255,255,255,0.32) !important;
  margin: 0 0 0.9rem !important;
  display: block !important;
}
.rr-metrics {
  display: grid !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 0.5rem !important;
  margin-bottom: 0.85rem !important;
}
.rr-metric {
  background: rgba(255,255,255,0.06) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  padding: 0.6rem 0.7rem !important;
}
.rr-metric__lbl {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.46rem !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  color: rgba(255,255,255,0.3) !important;
  margin: 0 0 0.22rem !important;
  display: block !important;
}
.rr-metric__val {
  font-family: 'PT Mono', monospace !important;
  font-size: 1rem !important;
  font-weight: 700 !important;
  color: #fff !important;
  line-height: 1 !important;
  display: block !important;
  margin: 0 !important;
}
.rr-metric__val.free { color: #4ade80 !important; }

.rr-sum-items {
  display: none !important;
  flex-direction: column !important;
  gap: 0.5rem !important;
  margin-bottom: 0.85rem !important;
  padding-bottom: 0.85rem !important;
  border-bottom: 1px solid rgba(255,255,255,0.07) !important;
}
.rr-sum-items.show { display: flex !important; }
.rr-smi {
  display: flex !important;
  justify-content: space-between !important;
  align-items: flex-start !important;
  gap: 0.45rem !important;
}
.rr-smi__name {
  font-family: 'Noto Sans', sans-serif !important;
  font-size: 0.76rem !important;
  font-weight: 600 !important;
  color: rgba(255,255,255,0.85) !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
  flex: 1 !important;
  min-width: 0 !important;
  margin: 0 !important;
}
.rr-smi__meta {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.48rem !important;
  color: rgba(255,255,255,0.32) !important;
  letter-spacing: 0.06em !important;
  margin: 1px 0 0 !important;
  display: block !important;
}
.rr-smi__price {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.76rem !important;
  font-weight: 700 !important;
  color: #fff !important;
  white-space: nowrap !important;
  flex-shrink: 0 !important;
  margin: 0 !important;
}
.rr-sum-line {
  display: flex !important;
  justify-content: space-between !important;
  align-items: baseline !important;
  margin-bottom: 0.32rem !important;
}
.rr-sum-lbl {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.54rem !important;
  letter-spacing: 0.1em !important;
  text-transform: uppercase !important;
  color: rgba(255,255,255,0.36) !important;
  margin: 0 !important;
}
.rr-sum-val {
  font-family: 'PT Mono', monospace !important;
  font-size: 0.76rem !important;
  font-weight: 700 !important;
  color: #fff !important;
  margin: 0 !important;
}
.rr-sum-val.free { color: #4ade80 !important; }
.rr-sum-div {
  height: 1px !important;
  background: rgba(255,255,255,0.07) !important;
  margin: 0.65rem 0 !important;
  display: block !important;
}
.rr-sum-total {
  display: flex !important;
  justify-content: space-between !important;
  align-items: baseline !important;
  margin-bottom: 1.15rem !important;
}
.rr-sum-total-lbl {
  font-family: 'Noto Sans', sans-serif !important;
  font-weight: 800 !important;
  font-size: 0.92rem !important;
  color: #fff !important;
  margin: 0 !important;
}
.rr-sum-total-val {
  font-family: 'PT Mono', monospace !important;
  font-size: 1.3rem !important;
  font-weight: 700 !important;
  color: #fff !important;
  letter-spacing: 0.02em !important;
  transition: transform 0.16s !important;
  display: inline-block !important;
  margin: 0 !important;
}
.rr-sum-total-val.bump { transform: scale(1.1) !important; }

/* ═══════════════════════════════════════════════════════
   BOTONES
   ══════════════════════════════════════════════════════ */
.rr-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 0.4rem !important;
  font-family: 'PT Mono', monospace !important;
  font-size: 0.62rem !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  padding: 0.85rem !important;
  border: 1px solid !important;
  cursor: pointer !important;
  font-weight: 700 !important;
  width: 100% !important;
  margin-bottom: 0.45rem !important;
  border-radius: 0 !important;
