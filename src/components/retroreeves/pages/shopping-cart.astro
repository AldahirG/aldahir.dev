<script define:vars={{ base }}>
  const SHIP    = 150
  const FREE_AT = 1299
  let cart = JSON.parse(localStorage.getItem('cart') || '[]')
  let pendingDel = null

  const fmx = n => '$' + Number(n).toLocaleString('es-MX') + ' MXN'
  const sub = () => cart.reduce((s, i) => s + i.price * (i.qty || 1), 0)
  const tot = s  => s >= FREE_AT ? s : s + SHIP

  function toast(msg) {
    const el = document.getElementById('rr-toast')
    el.textContent = msg
    el.classList.add('show')
    setTimeout(() => el.classList.remove('show'), 2400)
  }

  function updateBar() {
    const s       = sub()
    const missing = Math.max(0, FREE_AT - s)
    const pct     = Math.min(100, Math.round((s / FREE_AT) * 100))
    const bar   = document.getElementById('sb-bar')
    const lbl   = document.getElementById('sb-lbl')
    const pctEl = document.getElementById('sb-pct')
    if (bar)   { bar.style.width = pct + '%'; bar.classList.toggle('free', missing === 0) }
    if (pctEl) pctEl.textContent = pct + '%'
    if (lbl) {
      if (missing === 0) {
        lbl.classList.add('free')
        lbl.innerHTML = '¡<strong>Envío gratis</strong> aplicado en tu pedido!'
      } else {
        lbl.classList.remove('free')
        lbl.innerHTML = 'Agrega <strong>$' + missing.toLocaleString('es-MX') + '</strong> MXN más para envío gratis'
      }
    }
  }

  function updateSummary() {
    const s    = sub(), t = tot(s), free = s >= FREE_AT
    const n    = cart.reduce((a, i) => a + (i.qty || 1), 0)
    document.getElementById('s-sub').textContent   = fmx(s)
    document.getElementById('s-total').textContent = fmx(t)
    const sEl = document.getElementById('s-ship')
    const mSh = document.getElementById('m-ship')
    const mCt = document.getElementById('m-count')
    const tEl = document.getElementById('s-total')
    if (free) {
      if (sEl) { sEl.textContent = 'GRATIS'; sEl.classList.add('free') }
      if (mSh) { mSh.textContent = 'GRATIS'; mSh.classList.add('free') }
    } else {
      if (sEl) { sEl.textContent = fmx(SHIP); sEl.classList.remove('free') }
      if (mSh) { mSh.textContent = '$' + SHIP; mSh.classList.remove('free') }
    }
    if (mCt) mCt.textContent = n
    if (tEl) { tEl.classList.remove('bump'); void tEl.offsetWidth; tEl.classList.add('bump'); setTimeout(() => tEl.classList.remove('bump'), 180) }
  }

  function renderMiniItems() {
    const el = document.getElementById('sum-items')
    if (!cart.length) { el.classList.remove('show'); return }
    el.classList.add('show')
    el.innerHTML = cart.map(item => `
      <div class="rr-smi">
        <div style="flex:1;min-width:0;">
          <p class="rr-smi__name">${item.name}</p>
          <span class="rr-smi__meta">${[item.size && 'T:' + item.size, item.color && 'C:' + item.color, 'x' + (item.qty || 1)].filter(Boolean).join(' · ')}</span>
        </div>
        <span class="rr-smi__price">${fmx(item.price * (item.qty || 1))}</span>
      </div>`).join('')
  }

  function renderCart() {
    const c   = document.getElementById('items-container')
    const lbl = document.getElementById('cart-count-label')
    const btn = document.getElementById('btn-to-form')
    const n   = cart.reduce((s, i) => s + (i.qty || 1), 0)
    if (lbl) lbl.textContent = n + ' artículo' + (n !== 1 ? 's' : '')
    if (btn) btn.disabled = !cart.length

    if (!cart.length) {
      c.innerHTML = `
        <div class="rr-empty">
          <span class="rr-empty__icon">◻</span>
          <p class="rr-empty__title">Tu carrito está vacío</p>
          <span class="rr-empty__sub">Agrega productos desde la tienda</span>
          <a href="${base}/" class="rr-btn rr-btn--dk" style="max-width:210px;margin:0 auto;">Ver productos</a>
        </div>`
      const sw = document.getElementById('suggested-wrap')
      if (sw) sw.style.display = 'none'
      updateSummary(); updateBar()
      return
    }

    c.innerHTML = cart.map((item, idx) => {
      const isDrop = !!(item.drop || item.dropSlug)
      const qty    = item.qty || 1
      const total  = item.price * qty
      const imgSrc = item.image ? base + '/' + item.image : ''
      const meta   = [item.size ? 'Talla: ' + item.size : null, item.color ? 'Color: ' + item.color : null].filter(Boolean).join(' · ')
      return `
      <div class="rr-ticket${isDrop ? ' drop' : ''}" id="tk-${idx}">
        <div class="rr-ticket__body">
          <div class="rr-ticket__img">
            ${imgSrc
              ? `<img src="${imgSrc}" alt="${item.name}" loading="lazy"/>`
              : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'PT Mono',monospace;font-size:0.4rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(0,0,0,0.25);text-align:center;padding:.5rem;line-height:1.4;">${item.name}</div>`
            }
          </div>
          <div class="rr-ticket__info">
            <span class="rr-ticket__name">${item.name}${isDrop ? '<span class="rr-ticket__badge">Drop</span>' : ''}</span>
            <span class="rr-ticket__meta">${meta}</span>
          </div>
        </div>
        <hr class="rr-ticket__sep"/>
        <div class="rr-ticket__foot">
          <div class="rr-qty">
            <button class="rr-qty__btn" data-a="dec" data-i="${idx}" type="button">&#8722;</button>
            <span class="rr-qty__num" id="qn-${idx}">${qty}</span>
            <button class="rr-qty__btn" data-a="inc" data-i="${idx}" type="button">&#43;</button>
          </div>
          <span class="rr-ticket__price" id="tp-${idx}">$${total.toLocaleString('es-MX')} MXN${qty > 1 ? `<span class="rr-ticket__price-unit">($${item.price.toLocaleString('es-MX')} c/u)</span>` : ''}</span>
        </div>
        <button class="rr-ticket__remove" data-a="del" data-i="${idx}" type="button">✕ quitar</button>
      </div>`
    }).join('')

    c.querySelectorAll('[data-a]').forEach(btn => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.i), a = btn.dataset.a
        if (a === 'inc') {
          if ((cart[i].qty || 1) < 10) {
            cart[i].qty = (cart[i].qty || 1) + 1
            bumpNum(i); updateTicketPrice(i); save(); updateSummary(); updateBar()
          }
        }
        if (a === 'dec') {
          if ((cart[i].qty || 1) <= 1) { openDlg(i) }
          else { cart[i].qty = (cart[i].qty || 1) - 1; bumpNum(i); updateTicketPrice(i); save(); updateSummary(); updateBar() }
        }
        if (a === 'del') openDlg(i)
      })
    })
    updateSummary(); updateBar(); renderSuggested()
  }

  function bumpNum(idx) {
    const el = document.getElementById('qn-' + idx)
    if (!el) return
    el.textContent = cart[idx].qty || 1
    el.classList.remove('bump'); void el.offsetWidth; el.classList.add('bump')
    setTimeout(() => el.classList.remove('bump'), 180)
  }

  function updateTicketPrice(idx) {
    const el = document.getElementById('tp-' + idx)
    if (!el) return
    const item = cart[idx], qty = item.qty || 1, total = item.price * qty
    el.innerHTML = '$' + total.toLocaleString('es-MX') + ' MXN' + (qty > 1 ? '<span class="rr-ticket__price-unit">($' + item.price.toLocaleString('es-MX') + ' c/u)</span>' : '')
  }

  function renderSuggested() {
    const wrap = document.getElementById('suggested-wrap')
    const grid = document.getElementById('sug-grid')
    if (!wrap || !grid) return
    let all = []
    try { all = JSON.parse(localStorage.getItem('rr-products') || '[]') } catch(e) {}
    const inCart = new Set(cart.map(i => i.slug))
    const cands  = all.filter(p => !inCart.has(p.slug)).slice(0, 3)
    if (!cands.length) { wrap.style.display = 'none'; return }
    wrap.style.display = 'block'
    grid.innerHTML = cands.map(p => {
      const img = p.images?.[0] ? base + '/' + p.images[0] : ''
      return `
      <a href="${base}/product/${p.slug}" class="rr-sug-card">
        <div class="rr-sug-card__img">${img ? `<img src="${img}" alt="${p.name}" loading="lazy"/>` : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'PT Mono',monospace;font-size:0.42rem;text-transform:uppercase;color:rgba(0,0,0,0.26);text-align:center;padding:.5rem;">${p.name}</div>`}</div>
        <div class="rr-sug-card__info">
          <span class="rr-sug-card__name">${p.name}</span>
          <span class="rr-sug-card__price">$${p.price.toLocaleString('es-MX')} MXN</span>
        </div>
      </a>`
    }).join('')
    requestAnimationFrame(() => { wrap.querySelectorAll('.rr-reveal').forEach(el => el.classList.add('v')) })
  }

  function openDlg(idx) {
    pendingDel = idx
    document.getElementById('dlg-name').textContent = '¿Eliminar "' + (cart[idx]?.name ?? 'este artículo') + '" del carrito?'
    document.getElementById('rr-overlay').classList.add('open')
  }
  document.getElementById('dlg-yes')?.addEventListener('click', () => {
    if (pendingDel !== null) {
      const name = cart[pendingDel]?.name
      const tkEl = document.getElementById('tk-' + pendingDel)
      if (tkEl) { tkEl.classList.add('removing'); setTimeout(() => doDelete(pendingDel, name), 260) }
      else doDelete(pendingDel, name)
    }
    document.getElementById('rr-overlay').classList.remove('open')
  })
  function doDelete(idx, name) {
    cart.splice(idx, 1); pendingDel = null
    save(); renderCart()
    toast(name ? '"' + name + '" eliminado' : 'Artículo eliminado')
  }
  document.getElementById('dlg-no')?.addEventListener('click', () => {
    pendingDel = null; document.getElementById('rr-overlay').classList.remove('open')
  })
  document.getElementById('rr-overlay')?.addEventListener('click', e => {
    if (e.target === e.currentTarget) { pendingDel = null; e.currentTarget.classList.remove('open') }
  })

  function goTo(n) {
    document.getElementById('step-cart').style.display    = n === 1 ? 'block' : 'none'
    document.getElementById('step-form').style.display    = n === 2 ? 'block' : 'none'
    document.getElementById('step-success').style.display = n === 3 ? 'block' : 'none'
    document.getElementById('cta-1').style.display        = n === 1 ? 'block' : 'none'
    document.getElementById('cta-2').style.display        = n === 2 ? 'block' : 'none'
    ;[1,2,3].forEach(i => {
      const si = document.getElementById('si' + i), sn = document.getElementById('sn' + i)
      si.classList.remove('active','done')
      if (i < n) { si.classList.add('done'); sn.textContent = '✓' }
      else if (i === n) { si.classList.add('active'); sn.textContent = String(i) }
      else sn.textContent = String(i)
    })
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  const REQ = ['f-name','f-phone','f-address','f-city','f-state','f-cp']
  function validate() {
    let ok = true
    REQ.forEach(id => {
      const el = document.getElementById(id), err = document.querySelector('.rr-errmsg[data-for="' + id + '"]')
      const empty = !el?.value.trim()
      if (el) el.classList.toggle('err', empty)
      if (err) err.style.setProperty('display', empty ? 'block' : 'none', 'important')
      if (empty) ok = false
    })
    return ok
  }
  REQ.forEach(id => {
    document.getElementById(id)?.addEventListener('input', function() {
      this.classList.toggle('err', !this.value.trim())
      const err = document.querySelector('.rr-errmsg[data-for="' + id + '"]')
      if (err) err.style.setProperty('display', this.value.trim() ? 'none' : 'block', 'important')
    })
  })

  function buildWA() {
    const g = id => document.getElementById(id)?.value?.trim() ?? ''
    const s = sub(), free = s >= FREE_AT, t = tot(s)
    return 'https://wa.me/5217773019146?text=' + encodeURIComponent([
      'NUEVO PEDIDO — RETRO REEVES','',
      'DATOS DEL CLIENTE', 'Nombre: '+g('f-name'), 'Telefono: '+g('f-phone'),
      g('f-email')?'Correo: '+g('f-email'):null,'',
      'DIRECCION DE ENTREGA','Calle: '+g('f-address'),'Ciudad: '+g('f-city')+', '+g('f-state'),'C.P.: '+g('f-cp'),
      g('f-refs')?'Referencias: '+g('f-refs'):null,'',
      'ARTICULOS',
      ...cart.map(i=>'- '+i.name+(i.size?' | Talla: '+i.size:'')+(i.color?' | Color: '+i.color:'')+' | Cantidad: '+(i.qty||1)+' | Precio: $'+(i.price*(i.qty||1)).toLocaleString('es-MX')+' MXN'),'',
      'RESUMEN','Subtotal: $'+s.toLocaleString('es-MX')+' MXN','Envio: '+(free?'GRATIS':'$150 MXN'),'Total: $'+t.toLocaleString('es-MX')+' MXN',
      g('f-notes')?'\nNotas: '+g('f-notes'):null,'','Por favor confirmar disponibilidad y metodo de pago.',
    ].filter(l=>l!==null).join('\n'))
  }

  function save() { localStorage.setItem('cart', JSON.stringify(cart)); window.dispatchEvent(new Event('cartUpdated')) }

  document.getElementById('btn-to-form')?.addEventListener('click', () => { if (!cart.length) return; renderMiniItems(); goTo(2) })
  document.getElementById('btn-back')?.addEventListener('click', () => goTo(1))
  document.getElementById('btn-send-wa')?.addEventListener('click', () => {
    if (!validate()) { document.querySelector('.err')?.scrollIntoView({ behavior: 'smooth', block: 'center' }); return }
    window.open(buildWA(), '_blank')
    cart = []; save(); goTo(3); document.getElementById('cta-2').style.display = 'none'
  })

  const io = new IntersectionObserver(entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('v'); io.unobserve(e.target) } }), { threshold: 0.06 })
  document.querySelectorAll('.rr-reveal').forEach(el => io.observe(el))
  window.addEventListener('cartUpdated', () => { cart = JSON.parse(localStorage.getItem('cart') || '[]'); renderCart() })

  renderCart()
</script>
</Layout>